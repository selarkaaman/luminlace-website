{
  "version": 2,
  "name": "luminlace",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/products", "dest": "/products.html" },
    { "src": "/sourcing", "dest": "/sourcing.html" },
    { "src": "/suppliers", "dest": "/suppliers.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
